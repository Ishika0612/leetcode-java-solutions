class Solution {
    public int minOperations(String s) {
        int operations0=0;
        int operations1=0;

        for(int i=0;i<s.length();i++){
           //if string starts with 0
           if(i%2==0 && s.charAt(i)=='1'){
              operations0++;
           }
           if(i%2==1 && s.charAt(i)=='0' ){
             operations0++;
           }

           //if string starts with 1
           if(i%2==0 && s.charAt(i)=='0'){
              operations1++;
           }
           if(i%2==1 && s.charAt(i)=='1'){
              operations1++;
           }
        }

        return Math.min(operations0,operations1);
    }
}
